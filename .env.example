# ═══════════════════════════════════════════════════════════════
# BetterJob — إعداد الدومين الاحترافي + Brevo
# ═══════════════════════════════════════════════════════════════

# ── الدومين (بعد الشراء) ─────────────────────────────────────
# DOMAIN_NAME=mby-surveyor.com

# ── Brevo SMTP ────────────────────────────────────────────────
EMAIL_PROVIDER=brevo_smtp
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587

# Login من: Brevo → Settings → SMTP & API → SMTP → Login
# مثال: 7123456@smtp-brevo.com  (ليس بريدك الشخصي!)
SMTP_LOGIN=your_brevo_smtp_login_here
SMTP_PASSWORD=your_brevo_smtp_key_here

# المرسل الظاهر للشركات (يجب مصادقة الدومين أولاً في Brevo)
# يُقرأ من config.yaml → profile.sender_email
# مثال: jobs@mby-surveyor.com
